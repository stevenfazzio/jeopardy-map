# Copy to .env and fill in (or just export these in your shell).
# Loaded by pipeline/config.py via python-dotenv.

# Cohere API key — stage 02 embeds each clue with embed-v4.0, and stage 04
# (Toponymy) embeds candidate region-name keyphrases. Use a PRODUCTION key:
# trial keys are heavily rate-limited and make the ~568k-clue embed run crawl.
CO_API_KEY=

# Anthropic API key — stage 04 uses Claude to name the topic regions.
ANTHROPIC_API_KEY=
